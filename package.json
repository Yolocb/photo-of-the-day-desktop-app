{
  "name": "photo-of-the-day-app",
  "version": "1.0.0",
  "description": "Eine Desktop-Anwendung zur Anzeige von Fotos vom gleichen Kalendertag aus vergangenen Jahren",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "photos",
    "exif",
    "desktop-app",
    "photo-gallery"
  ],
  "author": "Photo Memory App",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "glob": "^10.3.10",
    "lucide": "^0.284.0"
  },
  "build": {
    "appId": "com.photomemory.photooftheday",
    "productName": "Photo of the Day",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
